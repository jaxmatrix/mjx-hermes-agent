# Loaded by `vite build --mode benchmark`, which is what `npm run dev:prodweb`
# runs. It produces a normal PRODUCTION frontend (minified, no HMR, no React
# dev-mode double-render) that additionally keeps the /dev/markdown-bench route,
# so the same measurements can be taken against dev and prod builds.
#
# Never used by `npm run build` (mode `production`), so a real release bundle
# still has no bench and no LaTeX fixture in it.
VITE_ENABLE_BENCH=true
