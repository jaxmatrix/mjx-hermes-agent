{
  "name": "@hermes/universal",
  "private": true,
  "version": "0.0.1",
  "description": "Hermes Universal — Tauri v2 client (desktop + Android + iOS from one codebase).",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "android:init": "tauri android init",
    "android:dev": "tauri android dev",
    "android:build:debug": "tauri android build --debug",
    "typecheck": "tsc -p . --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm run test && npm run build",
    "check:rust": "cargo check --manifest-path src-tauri/Cargo.toml"
  },
