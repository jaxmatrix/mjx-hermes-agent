{
  "$schema": "https://schema.tauri.app/config/2/capability",
  "identifier": "default",
  "description": "Default capabilities for Hermes Universal. The webview makes no network calls itself — all HTTP/WS traffic runs in Rust and is surfaced via events + IPC commands.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "os:allow-platform",
    "keyring:allow-initialize-keyring",
    "keyring:allow-get-password",
    "keyring:allow-set-password",
    "keyring:allow-delete-password",
    "keyring:allow-has-password",
    "mic:allow-check-permission",
    "mic:allow-request-permission",
    "opener:allow-open-url",
    "haptics:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:allow-read-file",
    "fs:allow-write-text-file",
    "notification:default",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:window:allow-start-dragging",
    "core:window:allow-is-maximized",
    "core:webview:allow-set-webview-zoom"
  ]
}
